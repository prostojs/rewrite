{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript"
  ],
  "env": {
    "node": true
  },
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-debugger": "error",
    "lines-between-class-members": [
      "error",
      "always"
    ],
    "typescript/explicit-function-return-type": "off",
    "typescript/no-empty-interface": "off",
    "typescript/no-inferrable-types": "off",
    "typescript/explicit-module-boundary-types": "off",
    "typescript/no-implied-eval": "off",
    "typescript/no-this-alias": "warn"
  },
  "ignorePatterns": [
    "index.js",
    "*.config.js",
    "scripts/*",
    "**/*.cjs.js",
    "**/*.cjs.prod.js",
    "**/*.esm-bundler.js",
    "**/*.esm-browser.js",
    "**/*.esm-browser.prod.js",
    "**/*.global.js",
    "**/*.global.prod.js",
    "**/dist/*.d.ts",
    "explorations/*",
    "**/__snapshots__/*",
    "**/__test__/*"
  ],
  "globals": {
    "__DYE_RESET__": "readonly",
    "__DYE_COLOR_OFF__": "readonly",
    "__DYE_BG_OFF__": "readonly",
    "__DYE_BOLD__": "readonly",
    "__DYE_BOLD_OFF__": "readonly",
    "__DYE_DIM__": "readonly",
    "__DYE_DIM_OFF__": "readonly",
    "__DYE_ITALIC__": "readonly",
    "__DYE_ITALIC_OFF__": "readonly",
    "__DYE_UNDERSCORE__": "readonly",
    "__DYE_UNDERSCORE_OFF__": "readonly",
    "__DYE_INVERSE__": "readonly",
    "__DYE_INVERSE_OFF__": "readonly",
    "__DYE_HIDDEN__": "readonly",
    "__DYE_HIDDEN_OFF__": "readonly",
    "__DYE_CROSSED__": "readonly",
    "__DYE_CROSSED_OFF__": "readonly",
    "__DYE_BLACK__": "readonly",
    "__DYE_BG_BLACK__": "readonly",
    "__DYE_BLACK_BRIGHT__": "readonly",
    "__DYE_BG_BLACK_BRIGHT__": "readonly",
    "__DYE_RED__": "readonly",
    "__DYE_BG_RED__": "readonly",
    "__DYE_RED_BRIGHT__": "readonly",
